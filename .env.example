# Fastify
HOST=0.0.0.0
PORT=8000
# CORS: allow browser calls from your Next app origin (set on THIS server, not in app/.env).
# Option A — explicit list (comma-separated):
# CORS_ORIGINS=https://sapai.amfphub.com
# Option B — same as FE_LINK when CORS_ORIGINS is omitted:
FE_LINK=http://localhost:3000
# Option C — allow any origin (no credentials cookies cross-site; Bearer header still works):
# CORS_ORIGINS=*
# Behind nginx/caddy: TRUST_PROXY=true

# MongoDB (required for chat jobs + API key auth)
MONGODB_URI=mongodb://localhost:27017/sapai
MONGODB_DB_NAME=

# Ollama — used by chat job runner (`POST /api/chat` on the job worker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.1
# Qwen 3 etc.: omit or false so replies go to message.content (not only thinking trace)
OLLAMA_THINK=false
# Embedding model (must match `ollama pull …`)
OLLAMA_EMBED_MODEL=nomic-embed-text
# Max chars per Ollama embed call (longer stored chunks are split and averaged)
OLLAMA_EMBED_MAX_CHARS=512
# Stored FAQ chunk size (default 1200; embedding splits internally when needed)
FAQ_CHUNK_MAX_CHARS=1200
FAQ_CHUNK_OVERLAP=150
# Mongo insert batch size during chunking; Ollama embed batch size during indexing
FAQ_CHUNK_INSERT_BATCH=50
FAQ_EMBED_BATCH_SIZE=8

# Qdrant (FAQ chunk vectors) — collection vector size must match OLLAMA_EMBED_MODEL output
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_FAQ_COLLECTION=faq_chunks

# API keys — fallback req/min when the user has no resolvable plan (`0` on plan = unlimited)
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120

# Google reCAPTCHA v3 — required for POST /api/v1/embed/chat when set (omit locally to skip verification)
# RECAPTCHA_SECRET_KEY=your-secret-key
# RECAPTCHA_MIN_SCORE=0.5

# Embed visitor dedupe: one embedvisits row per apiKeyId + raw client IP
